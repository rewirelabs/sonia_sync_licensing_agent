{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "ui_kits/sonia-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|iconLeft|iconRight|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, iconLeft, iconRight, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|tertiary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'tertiary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|active|disabled|label|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, size, active, disabled, label, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|type|mono|disabled|invalid|iconLeft|size|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, type, mono, disabled, invalid, iconLeft, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|stroke|label|showLabel|style|key|ref|className|style|children)$/]",
        "message": "<MatchRing> doesn't accept that prop. Declared props: value, size, stroke, label, showLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoodChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:mood|children|color|removable|onRemove|style|key|ref|className|style|children)$/]",
        "message": "<MoodChip> doesn't accept that prop. Declared props: mood, children, color, removable, onRemove, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoodChip'] > JSXAttribute[name.name='mood'] > Literal[value!=/^(?:calm|mellow|warm|energetic|intense)$/]",
        "message": "<MoodChip> mood must be one of 'calm' | 'mellow' | 'warm' | 'energetic' | 'intense'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SafetyBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|label|style|key|ref|className|style|children)$/]",
        "message": "<SafetyBadge> doesn't accept that prop. Declared props: state, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SafetyBadge'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:clear|review|block)$/]",
        "message": "<SafetyBadge> state must be one of 'clear' | 'review' | 'block'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrackMood'] > JSXAttribute > JSXIdentifier[name!=/^(?:mood|label|key|ref|className|style|children)$/]",
        "message": "<TrackMood> doesn't accept that prop. Declared props: mood, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|bars|height|barWidth|gap|style|key|ref|className|style|children)$/]",
        "message": "<Waveform> doesn't accept that prop. Declared props: state, bars, height, barWidth, gap, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:idle|listening|thinking|speaking)$/]",
        "message": "<Waveform> state must be one of 'idle' | 'listening' | 'thinking' | 'speaking'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
